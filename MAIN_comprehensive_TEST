def fetch_all_pages(endpoint, deep_populate="", quiet=False):
    """Gracefully handles Strapi page-by-page server iteration bounds."""
    all_records = []
    page = 1
    page_size = 100
    separator = "&" if "?" in endpoint else "?"

    while True:
        url = f"{BASE_URL}{endpoint}{separator}pagination[page]={page}&pagination[pageSize]={page_size}{deep_populate}"
        try:
            response = requests.get(url, headers=HEADERS)
            if response.status_code != 200:
                if not quiet:
                    print(f"     ⚠️  HTTP {response.status_code} on {endpoint} page {page}")
                break
            data = response.json().get("data", [])
            if not data:
                break
            all_records.extend(data)
            page += 1
        except Exception as exc:
            if not quiet:
                print(f"     ⚠️  Request failed on {endpoint}: {exc}")
            break
    return all_records


def fetch_collection(label, endpoints, populate="", platform_scoped=True):
    """Try multiple Strapi collection paths until one returns data."""
    for endpoint in endpoints:
        if platform_scoped:
            scoped = f"{endpoint}?filters[parent_platform][id]={PLATFORM_ID}"
        else:
            scoped = endpoint if "?" in endpoint else f"{endpoint}?"
        records = fetch_all_pages(scoped, populate, quiet=True)
        if records:
            print(f"     ✅ {label}: {len(records)} records via {endpoint}")
            return records
    print(f"     ⚠️  {label}: no records (tried {', '.join(endpoints)})")
    return []


def save_raw_json(name, records):
    path = os.path.join(RAW_DIR, f"{name}.json")
    with open(path, "w", encoding="utf-8") as f:
        json.dump({"data": records}, f, indent=2, ensure_ascii=False)
    return path


def write_csv(df, filename, also_root=True):
    """Write to relationships/entities/analytics and optionally the flat output dir."""
    if filename.startswith("link_") or filename.endswith("_links.csv"):
        path = os.path.join(RELATIONSHIPS_DIR, filename)
    elif filename in {
        "initiatives_unified.csv",
        "listening_pipeline.csv",
        "portfolio_matrix_inputs.csv",
    }:
        path = os.path.join(ANALYTICS_DIR, filename)
    else:
        path = os.path.join(ENTITIES_DIR, filename)

    df.to_csv(path, index=False)
    if also_root:
        df.to_csv(os.path.join(OUTPUT_DIR, filename), index=False)
    return path


def write_alias_csv(df, filenames):
    """Write the same frame under multiple filenames, preserving compatibility aliases."""
    for filename in filenames:
        write_csv(df, filename)


def get_data_list(data_field):
    if isinstance(data_field, list):
        return data_field
    if isinstance(data_field, dict):
        return data_field.get("data", []) or []
    return []


def get_single_ref(node):
    if not isinstance(node, dict):
        return None
    data = node.get("data") if "data" in node else node
    if isinstance(data, list):
        return data[0] if data else None
    if isinstance(data, dict) and data.get("id"):
        return data
    return None


def get_ref_id(node):
    ref = get_single_ref(node)
    return ref.get("id") if ref else None


def format_location(loc):
    if not isinstance(loc, dict):
        return ""
    if loc.get("address"):
        return loc.get("address", "")
    if loc.get("name"):
        return loc.get("name", "")
    return json.dumps(loc, ensure_ascii=False)

