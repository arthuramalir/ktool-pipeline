    )
    write_csv(
        pd.DataFrame(
            [
                {
                    "id": x.get("id"),
                    "name": x.get("attributes", {}).get("name", "Unnamed"),
                    "description": x.get("attributes", {}).get("description", ""),
                }
                for x in raw_themes
            ]
        ),
        "thematic_areas.csv",
    )
    sessions_df = pd.DataFrame([extract_session_row(x) for x in raw_sessions]) if raw_sessions else pd.DataFrame(columns=["id", "name", "description", "type", "status", "date", "created_at", "updated_at"])
    write_csv(sessions_df, "sessions.csv")
    write_csv(
        pd.DataFrame(
            [
                {
                    "id": x.get("id"),
                    "quote": x.get("attributes", {}).get("quote") or x.get("attributes", {}).get("text") or "",
                    "date": x.get("attributes", {}).get("date"),
                    "reference_number": x.get("attributes", {}).get("reference_number"),
                }
                for x in raw_informations
            ]
        ),
        "informations.csv",
    )

    for i_type, collection in [("project", raw_projects), ("pilot", raw_pilots), ("prototype", raw_prototypes)]:
        rows = [extract_initiative_row(item, i_type) for item in collection]
        write_csv(pd.DataFrame(rows), f"{i_type}s.csv")

    print("     Primary entity tables written.")

    print("Step 2: Building unified initiatives and initiative-side links...")
    unified_initiatives = []
    init_perception_links = []
    init_lead_agent_links = []
    init_agent_links = []
    init_partner_links = []
    init_theme_links = []
    initiative_interconnections = []
    initiative_indicators = []

    init_map = {"project": raw_projects, "pilot": raw_pilots, "prototype": raw_prototypes}

    for i_type, collection in init_map.items():
        for item in collection:
            g_id = f"{i_type}_{item.get('id')}"
            attrs = item.get("attributes", {})
            unified_initiatives.append(extract_initiative_row(item, i_type))

            for p in get_data_list(attrs.get("perceptions")):
                init_perception_links.append({"initiative_global_id": g_id, "perception_id": p.get("id")})

            for ag in get_data_list(attrs.get("agents")):
                init_agent_links.append({"initiative_global_id": g_id, "agent_id": ag.get("id"), "role": "collaborator"})

            la_node = attrs.get("lead_agent") or attrs.get("lead_agents")
            for lead_item in get_data_list(la_node):
                init_lead_agent_links.append({"initiative_global_id": g_id, "agent_id": lead_item.get("id"), "role": "lead_agent"})
                init_agent_links.append({"initiative_global_id": g_id, "agent_id": lead_item.get("id"), "role": "lead"})

            partners = attrs.get("partners")
            if isinstance(partners, list):
                for prt in partners:
                    init_partner_links.append({"initiative_global_id": g_id, "partner_sector": prt})
            elif isinstance(partners, dict) and "data" in partners:
                for prt in partners.get("data", []):
                    init_partner_links.append(
                        {
                            "initiative_global_id": g_id,
                            "partner_sector": prt.get("attributes", {}).get("name") if isinstance(prt, dict) else prt,
                        }
                    )

            themes_combined = get_data_list(attrs.get("thematic_areas")) + get_data_list(attrs.get("topics_thematic_areas"))
            for th in themes_combined:
                if isinstance(th, dict):
                    init_theme_links.append(
                        {
                            "initiative_global_id": g_id,
                            "thematic_area_id": th.get("id"),
                            "theme_name": th.get("attributes", {}).get("name") or th.get("attributes", {}).get("title"),
                        }
                    )

            for ind in get_data_list(attrs.get("indicators")):
                if isinstance(ind, dict):
                    ind_attrs = ind.get("attributes", {}) or {}
                    initiative_indicators.append(
                        {
                            "initiative_global_id": g_id,
                            "indicator_id": ind.get("id"),
                            "indicator_name": ind_attrs.get("name") or ind_attrs.get("title") or "Unnamed Indicator",
                        }
                    )

            for iconn in get_data_list(attrs.get("interconnections")):
                for target_id, target_kind, weight, conn_type in resolve_interconnection_targets(
                    iconn, source_native_id=item.get("id"), source_type=i_type
                ):
                    if target_id == g_id:
                        continue
                    initiative_interconnections.append(
                        {
                            "source_initiative_global_id": g_id,
                            "target_global_id": target_id,
                            "target_kind": target_kind,
                            "connection_type": conn_type,
                            "weight": weight,
                        }
                    )

    initiative_interconnections = pd.DataFrame(initiative_interconnections).drop_duplicates().to_dict("records") if initiative_interconnections else []

    write_csv(pd.DataFrame(unified_initiatives), "initiatives_unified.csv")
    write_alias_csv(pd.DataFrame(init_perception_links), ["initiative_perception_links.csv", "link_initiative_perceptions.csv"])
    write_alias_csv(pd.DataFrame(init_lead_agent_links), ["initiative_lead_agent_links.csv"])
    write_alias_csv(pd.DataFrame(init_agent_links), ["agent_initiative_links.csv", "link_initiative_agents.csv"])
    write_alias_csv(pd.DataFrame(init_partner_links), ["initiative_partner_links.csv", "link_initiative_partners.csv"])
    write_alias_csv(pd.DataFrame(init_theme_links), ["initiative_thematic_area_links.csv", "link_initiative_themes.csv"])
    write_alias_csv(pd.DataFrame(initiative_interconnections), ["initiative_initiative_links.csv", "link_initiative_interconnections.csv"])
    write_csv(pd.DataFrame(initiative_indicators), "link_initiative_indicators.csv")
    print("     Initiative-side relationship tables written.")

    print("Step 3: Building agent-side relationship tables...")
    agent_theme_links = []
    agent_capability_links = []
    agent_indicator_links = []
    agent_initiative_links = []
    agent_interconnections = []

    agent_initiative_fields = [
        ("projects", "collaborator"),
        ("pilots", "collaborator"),
        ("prototypes", "collaborator"),
        ("projects_leaded", "lead"),
        ("pilots_leaded", "lead"),
        ("prototypes_leaded", "lead"),
    ]

    for agent in raw_agents:
        agent_id = agent.get("id")
        attrs = agent.get("attributes", {})

        for th in get_data_list(attrs.get("topics_thematic_areas")):
            agent_theme_links.append({"agent_id": agent_id, "thematic_area_id": th.get("id")})

        for cap in get_data_list(attrs.get("agent_capabilities")):
            agent_capability_links.append({"agent_id": agent_id, "capability_id": cap.get("id")})

        for ind in get_data_list(attrs.get("indicators")):
            if isinstance(ind, dict):
                agent_indicator_links.append({"agent_id": agent_id, "indicator_id": ind.get("id")})

        for field, role in agent_initiative_fields:
            base_field = field.replace("_leaded", "")
            init_type = INITIATIVE_TYPE_MAP.get(base_field, "project")
            for initiative in get_data_list(attrs.get(field)):
                agent_initiative_links.append(
                    {
                        "agent_id": agent_id,
                        "initiative_global_id": f"{init_type}_{initiative.get('id')}",
                        "link_role": role,
                        "source_field": field,
                    }
                )

        for iconn in get_data_list(attrs.get("interconnections")):
            for target_id, target_kind, weight, conn_type in resolve_interconnection_targets(
                iconn, source_native_id=agent_id, source_type="agent"
            ):
                agent_interconnections.append(
                    {
                        "source_agent_id": agent_id,
                        "target_global_id": target_id,
                        "target_kind": target_kind,
                        "connection_type": conn_type,
                        "weight": weight,
                    }
                )

    write_csv(pd.DataFrame(agent_theme_links), "link_agent_thematic_areas.csv")
    write_csv(pd.DataFrame(agent_capability_links), "link_agent_capabilities.csv")
    write_csv(pd.DataFrame(agent_indicator_links), "link_agent_indicators.csv")
    if agent_initiative_links:
        agent_init_df = pd.DataFrame(agent_initiative_links).drop_duplicates()
        write_csv(agent_init_df, "link_agent_initiatives.csv")
    write_csv(pd.DataFrame(agent_interconnections), "link_agent_interconnections.csv")
    print("     Agent-side relationship tables written.")

    print("Step 4: Mapping qualitative evidence chains...")
    edge_info_channel = []
    edge_info_pattern = []
    edge_info_value = []
    perception_challenge_links = []
    info_pattern_connection_rows = []
    edge_pattern_perception = []

    for inf in raw_informations:
        inf_id = inf.get("id")
        i_attrs = inf.get("attributes", {})

        ch_id = get_ref_id(i_attrs.get("channel"))
        if ch_id:
            edge_info_channel.append({"information_id": inf_id, "channel_id": ch_id})

        for pat in get_data_list(i_attrs.get("patterns")):
            if isinstance(pat, dict) and pat.get("id"):
                edge_info_pattern.append({"information_id": inf_id, "pattern_id": pat.get("id")})

        for conn in get_data_list(i_attrs.get("information_pattern_connections")):
            conn_id = conn.get("id") if isinstance(conn, dict) else None
            for pat in get_data_list(conn.get("attributes", {}).get("patterns")):
                if isinstance(pat, dict) and pat.get("id"):
                    edge_info_pattern.append({"information_id": inf_id, "pattern_id": pat.get("id")})
                    if conn_id is not None:
                        info_pattern_connection_rows.append(
                            {
                                "information_pattern_connection_id": conn_id,
                                "information_id": inf_id,
                                "pattern_id": pat.get("id"),
                                "connection_type": conn.get("attributes", {}).get("type") or conn.get("attributes", {}).get("connection_type") or "",
                                "weight": conn.get("attributes", {}).get("strength") or conn.get("attributes", {}).get("weight") or "",
                            }
                        )

        for val in get_data_list(i_attrs.get("values")):
            if isinstance(val, dict) and val.get("id"):
                edge_info_value.append({"information_id": inf_id, "value_id": val.get("id")})

    for perception in raw_perceptions:
        perception_id = perception.get("id")
        for challenge in get_data_list(perception.get("attributes", {}).get("challenge_opportunities")):
            if isinstance(challenge, dict) and challenge.get("id"):
                perception_challenge_links.append(
                    {
                        "perception_id": perception_id,
                        "challenge_id": challenge.get("id"),
                        "challenge_name": challenge.get("attributes", {}).get("name") or challenge.get("attributes", {}).get("title") or "",
                    }
                )

    for pat in raw_patterns:
        pat_id = pat.get("id")
        for per in get_data_list(pat.get("attributes", {}).get("perceptions")):
            if isinstance(per, dict) and per.get("id"):
                edge_pattern_perception.append({"pattern_id": pat_id, "perception_id": per.get("id")})

    write_alias_csv(pd.DataFrame(edge_info_channel), ["channel_information_links.csv", "link_information_channels.csv"])
    write_alias_csv(pd.DataFrame(edge_info_pattern), ["information_pattern_links.csv", "link_information_patterns.csv"])
    write_alias_csv(pd.DataFrame(edge_info_value), ["information_value_links.csv", "link_information_values.csv"])
    write_alias_csv(pd.DataFrame(edge_pattern_perception), ["pattern_perception_links.csv", "link_pattern_perceptions.csv"])
    write_alias_csv(pd.DataFrame(perception_challenge_links), ["perception_challenge_links.csv"])
    write_alias_csv(pd.DataFrame(columns=["value_id", "perception_id"]), ["value_perception_links.csv"])
    info_pattern_connection_df = (
        pd.DataFrame(info_pattern_connection_rows)
        if info_pattern_connection_rows
        else pd.DataFrame(columns=["information_pattern_connection_id", "information_id", "pattern_id", "connection_type", "weight"])
    )
    write_alias_csv(info_pattern_connection_df, ["information_pattern_connections.csv"])
    print("     Qualitative link tables written.")

    print("Step 5: Compiling analytical views...")
    listening_pipeline = []
    for inf in raw_informations:
        inf_id = inf.get("id")
        i_attrs = inf.get("attributes", {})

        ch_node = i_attrs.get("channel", {})
        ch_name = "Unknown Channel"
        ch_ref = get_single_ref(ch_node)
        if ch_ref:
            ch_name = ch_ref.get("attributes", {}).get("name", "Unknown Channel")

        p_names = [
            p.get("attributes", {}).get("name")
            for p in get_data_list(i_attrs.get("patterns"))
            if isinstance(p, dict)
        ]
        v_names = [
            entity_name(v.get("attributes", {}))
            for v in get_data_list(i_attrs.get("values"))
            if isinstance(v, dict)
        ]

        listening_pipeline.append(
            {
                "information_id": inf_id,
                "channel_name": ch_name,
                "information_text": i_attrs.get("quote") or i_attrs.get("text") or "",
                "pattern_names": " | ".join(filter(None, p_names)),
                "value_names": " | ".join(filter(None, v_names)),
            }
        )

    write_csv(pd.DataFrame(listening_pipeline), "listening_pipeline.csv")

    portfolio_rows = []
    perception_by_init = {}
    for link in init_perception_links:
        perception_by_init.setdefault(link["initiative_global_id"], []).append(link["perception_id"])

    for row in unified_initiatives:
        g_id = row["initiative_global_id"]
        portfolio_rows.append(
            {
                "initiative_global_id": g_id,
                "initiative_type": row["initiative_type"],
                "initiative_name": row["title"],
                "impact_level": row["impact_level"],
                "disruption_level": row["disruption_level"],
                "perception_count": len(perception_by_init.get(g_id, [])),
            }
        )
    write_csv(pd.DataFrame(portfolio_rows), "portfolio_matrix_inputs.csv")

    print(f"     Summary: {len(raw_agents)} agents | {len(raw_projects)} projects | {len(raw_pilots)} pilots | {len(raw_prototypes)} prototypes")
    print(f"              {len(raw_informations)} informations | {len(raw_challenges)} challenges | {len(raw_values)} values | {len(raw_themes)} themes")

    print("========================================================================")
    print(f"SUCCESS: Artifacts written to {OUTPUT_DIR}")
    print(f"  entities/       {len(os.listdir(ENTITIES_DIR))} files")
    print(f"  relationships/  {len(os.listdir(RELATIONSHIPS_DIR))} files")
    print(f"  analytics/      {len(os.listdir(ANALYTICS_DIR))} files")
    print(f"  raw/            {len(os.listdir(RAW_DIR))} JSON archives")
    print("========================================================================")


if __name__ == "__main__":
    build_comprehensive_ecosystem()
