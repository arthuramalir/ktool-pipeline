def flatten_link_rows(items, source_key, target_key, source_prefix=None, target_prefix=None, extra_fields=None):
    rows = []
    for item in items:
        source_value = item.get(source_key)
        target_value = item.get(target_key)
        if source_value is None or target_value is None:
            continue
        row = {
            source_key: source_value,
            target_key: target_value,
        }
        if source_prefix is not None:
            row[f"{source_key}_global_id"] = f"{source_prefix}_{source_value}"
        if target_prefix is not None:
            row[f"{target_key}_global_id"] = f"{target_prefix}_{target_value}"
        if extra_fields:
            row.update(extra_fields(item))
        rows.append(row)
    return rows


