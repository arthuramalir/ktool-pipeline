import json

def extract_names(data):
    """Pipe-separated names/titles of populated relations."""
    names = []

    for obj in get_data_list(data):
        if not isinstance(obj, dict):
            continue

        attrs = obj.get("attributes", {})

        name = (
            attrs.get("name")
            or attrs.get("title")
            or attrs.get("value")
            or attrs.get("label")
        )

        if name:
            names.append(str(name))

    return " | ".join(names)


def extract_ids(data):
    """Pipe-separated ids of populated relations."""
    ids = []

    for obj in get_data_list(data):
        if isinstance(obj, dict) and obj.get("id") is not None:
            ids.append(str(obj["id"]))

    return " | ".join(ids)


def preserve_complex(value):
    """Keep full JSON for nested objects."""
    if value is None:
        return ""

    try:
        return json.dumps(value, ensure_ascii=False)
    except Exception:
        return str(value)

def resolve_interconnection_targets(iconn, source_native_id=None, source_type=None):
    """Extract all linked entities from a Strapi interconnection component."""
    if not isinstance(iconn, dict):
        return []

    iconn_attrs = iconn.get("attributes", iconn)
    conn_type = iconn_attrs.get("type") or iconn_attrs.get("connection_type")
    weight = iconn_attrs.get("strength") or iconn_attrs.get("weight") or "unknown"
    results = []

    for field in ["projects", "pilots", "prototypes", "protots", "prototype_evolutions"]:
        init_type = INITIATIVE_TYPE_MAP[field]
        for target in get_data_list(iconn_attrs.get(field)):
            if not isinstance(target, dict) or not target.get("id"):
                continue
            tid = target.get("id")
            if source_native_id is not None and source_type == init_type and tid == source_native_id:
                continue
            results.append((f"{init_type}_{tid}", init_type, weight, conn_type))

    for target in get_data_list(iconn_attrs.get("agents")):
        if isinstance(target, dict) and target.get("id"):
            tid = target.get("id")
            if source_native_id is not None and source_type == "agent" and tid == source_native_id:
                continue
            results.append((f"agent_{tid}", "agent", weight, conn_type))

    for target in get_data_list(iconn_attrs.get("perceptions")):
        if isinstance(target, dict) and target.get("id"):
            tid = target.get("id")
            if source_native_id is not None and source_type == "perception" and tid == source_native_id:
                continue
            results.append((f"perception_{tid}", "perception", weight, conn_type))

    return results


def derive_challenges(raw_challenges, raw_perceptions, raw_informations):
    derived = list(raw_challenges)
    seen = {item.get("id") for item in derived if item.get("id")}

    for collection in (raw_perceptions, raw_informations):
        for item in collection:
            for ch in get_data_list(item.get("attributes", {}).get("challenge_opportunities")):
                cid = ch.get("id")
                if cid and cid not in seen:
                    seen.add(cid)
                    derived.append(ch)
    return derived


def derive_values(raw_values, raw_informations):
    derived = list(raw_values)
    seen = {item.get("id") for item in derived if item.get("id")}

    for inf in raw_informations:
        for val in get_data_list(inf.get("attributes", {}).get("values")):
            vid = val.get("id")
            if vid and vid not in seen:
                seen.add(vid)
                derived.append(val)
    return derived


def derive_patterns(raw_patterns, raw_informations, raw_connections):
    derived = list(raw_patterns)
    seen = {item.get("id") for item in derived if item.get("id")}

    for inf in raw_informations:
        inf_attrs = inf.get("attributes", {})
        for pat in get_data_list(inf_attrs.get("patterns")):
            pid = pat.get("id")
            if pid and pid not in seen:
                seen.add(pid)
                derived.append(pat)
        for conn in get_data_list(inf_attrs.get("information_pattern_connections")):
            for pat in get_data_list(conn.get("attributes", {}).get("patterns")):
                pid = pat.get("id")
                if pid and pid not in seen:
                    seen.add(pid)
                    derived.append(pat)

    platform_info_ids = {inf.get("id") for inf in raw_informations}
    for conn in raw_connections:
        for inf in get_data_list(conn.get("attributes", {}).get("informations")):
            if inf.get("id") not in platform_info_ids:
                continue
            for pat in get_data_list(conn.get("attributes", {}).get("patterns")):
                pid = pat.get("id")
                if pid and pid not in seen:
                    seen.add(pid)
                    derived.append(pat)
    return derived


